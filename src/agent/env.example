# =============================================================================
# vedio_split — minimal .env (copy to src/agent/.env)
# =============================================================================
# core.config.Config uses extra="ignore": other keys in your .env are harmless.

# --- LLM (required: match DEFAULT_MODEL with the right key) ---------------
DEFAULT_MODEL=deepseek/deepseek-chat

DEEPSEEK_API_KEY=
# QWEN_API_KEY=
# OPENAI_API_KEY=

# Optional: if you use OpenAI-compatible models under other env names, set via code or export.

# --- Logging (optional) ------------------------------------------------------
LOG_LEVEL=INFO
# File log path relative to src/agent, or empty / "-" / "none" = stderr only
LOG_FILE=-
